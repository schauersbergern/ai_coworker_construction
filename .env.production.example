# Produktions-Env für employees.aicoreinfra.de
# Auf dem Server als /home/deploy/ai_coworker_construction/.env anlegen (NICHT committen).
# docker-compose.prod.yml liest diese Datei via env_file.

# --- Datenbank (dedizierter db-Container) ---
# Wird auch von docker-compose.prod.yml zum Bauen der DATABASE_URL genutzt.
POSTGRES_PASSWORD="<starkes-zufalls-passwort>"

# --- Auth.js ---
AUTH_SECRET="<openssl rand -base64 32>"
AUTH_URL="https://employees.aicoreinfra.de"
AUTH_TRUST_HOST="true"

# --- Magic-Link E-Mail (dein vorhandener SMTP-Zugang) ---
EMAIL_SERVER="smtp://USER:PASSWORT@HOST:587"
EMAIL_FROM="noreply@aicoreinfra.de"

# --- Claude (PDF-Export) ---
ANTHROPIC_API_KEY="<dein-anthropic-key>"
ANTHROPIC_MODEL="claude-sonnet-4-5"

# --- Inngest Cloud (Free Tier) ---
INNGEST_EVENT_KEY="<aus-inngest-dashboard>"
INNGEST_SIGNING_KEY="<aus-inngest-dashboard>"

# --- Storage / Whisper (im Container) ---
STORAGE_DIR="/app/storage"
WHISPER_MODEL="small"
WHISPER_TIMEOUT_MS="120000"

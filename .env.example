DATABASE_URL="postgresql://baudoku:baudoku@localhost:5432/baudoku?schema=public"
AUTH_SECRET="dev-secret-change-me"
AUTH_URL="http://localhost:3000"
# Login: Google OAuth (lokale Redirect-URI: http://localhost:3000/api/auth/callback/google)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# Kommaseparierte E-Mails mit Zugriff
ALLOWED_EMAILS=""
ORG_NAME="Pilot-Büro"
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""
STORAGE_DIR="./storage"
# Transkription: die App spricht den Whisper-Worker via WHISPER_URL an.
# Lokal: `pnpm setup:whisper` einmalig, dann `pnpm dev:whisper` (Worker auf :8001) und:
WHISPER_URL="http://localhost:8001/transcribe"
WHISPER_VENV=".venv-whisper"
WHISPER_MODEL="small"
WHISPER_TIMEOUT_MS="120000"
# (In Prod setzt docker-compose.prod.yml WHISPER_URL auf den whisper-Service.)
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-4-5"

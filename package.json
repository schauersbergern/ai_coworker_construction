{
  "name": "baudoku",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.4.1",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:test:migrate": "bash scripts/test-db.sh",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev:inngest": "npx inngest-cli@latest dev -u http://localhost:3000/api/inngest",
    "setup:whisper": "bash scripts/whisper-setup.sh",
    "dev:whisper": ".venv-whisper/bin/python scripts/whisper_server.py",
    "seed:coworkers": "tsx scripts/seed-coworkers.ts",
    "lint:boundaries": "depcruise src --config .dependency-cruiser.cjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "@auth/prisma-adapter": "^2.11.2",
    "@prisma/client": "^6.19.3",
    "@react-pdf/renderer": "^4.5.1",
    "exifr": "^7.1.3",
    "inngest": "^4.5.0",
    "next": "16.2.6",
    "next-auth": "5.0.0-beta.31",
    "nodemailer": "^8.0.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1",
    "sharp": "^0.34.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dependency-cruiser": "^17.4.3",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "prisma": "^6.19.3",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.8"
  }
}
